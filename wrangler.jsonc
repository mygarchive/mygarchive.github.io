#:schema node_modules/wrangler/config-schema.json
name = "game-list"
main = ".open-next/worker.js"
compatibility_date = "2026-06-14"
compatibility_flags = ["nodejs_compat"]

# ----------------------------------------------------------------
# بخش حیاتی: آدرس‌دهی فایل‌های استاتیک، CSSها و فونت‌ها برای حل ارور 404
# ----------------------------------------------------------------
[assets]
directory = ".open-next/assets"
binding = "ASSETS"

# ----------------------------------------------------------------
# اتصال به دیتابیس ابری KV کلودفلر شما
# ----------------------------------------------------------------
[[kv_namespaces]]
binding = "GAME_KV"
id = "a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1" # ⚠️ توجه: نیازی به تغییر این آی‌دی نیست، کلودفلر خودش بایندینگ را ست می‌کند.

# ----------------------------------------------------------------
# تنظیمات پیشرفته برای کش و بهینه‌سازی سرعت لود در سراسر جهان
# ----------------------------------------------------------------
[[kv_namespaces]]
binding = "NEXT_CACHE_WORKERS_KV"
preview_binding = "NEXT_CACHE_WORKERS_KV_PREVIEW"
id = "NEXT_CACHE_WORKERS_KV"

[vars]
NEXT_ANALYTICS_ID = ""
